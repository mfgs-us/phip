          "z": 1,
          "a": 2
        },
        "alpha": {
          "c": 3,
          "b": 4
        }
      },
      "canonical": "{\"alpha\":{\"b\":4,\"c\":3},\"outer\":{\"a\":2,\"z\":1}}",
      "canonical_bytes_hex": "7b22616c706861223a7b2262223a342c2263223a337d2c226f75746572223a7b2261223a322c227a223a317d7d",
      "canonical_byte_length": 45
    },
    {
      "name": "unicode-values",
